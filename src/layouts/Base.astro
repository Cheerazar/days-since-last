---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      // Runs before first paint so the chosen theme never flashes.
      (() => {
        let theme = 'dark';
        try {
          theme =
            localStorage.getItem('theme') ??
            (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        } catch {}
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#07090c" />
    <meta property="og:site_name" content="Days Since Last" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta name="twitter:card" content="summary_large_image" />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link
      rel="preload"
      href="/fonts/DSEG7Classic-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      import.meta.env.PROD && (
        <>
          {/* Queues custom events until the Vercel Analytics beacon loads. */}
          <script is:inline>
            window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
          </script>
          <script is:inline defer src="/_vercel/insights/script.js" />
        </>
      )
    }
    {
      /* Umami (share-click events). Inert until PUBLIC_UMAMI_WEBSITE_ID is
         set in the build environment — set it in Vercel and redeploy. */
      import.meta.env.PROD && import.meta.env.PUBLIC_UMAMI_WEBSITE_ID && (
        <script
          is:inline
          defer
          src="https://cloud.umami.is/script.js"
          data-website-id={import.meta.env.PUBLIC_UMAMI_WEBSITE_ID}
        />
      )
    }
  </head>
  <body>
    <button id="theme-toggle" aria-label="Toggle light or dark theme" title="Toggle theme">
      <svg class="i-sun" viewBox="0 0 24 24" width="17" height="17" aria-hidden="true">
        <circle cx="12" cy="12" r="4.6" fill="currentColor"></circle>
        <g stroke="currentColor" stroke-width="1.9" stroke-linecap="round">
          <path d="M12 2.2v2.6M12 19.2v2.6M2.2 12h2.6M19.2 12h2.6M4.9 4.9l1.9 1.9M17.2 17.2l1.9 1.9M19.1 4.9l-1.9 1.9M6.8 17.2l-1.9 1.9"></path>
        </g>
      </svg>
      <svg class="i-moon" viewBox="0 0 24 24" width="17" height="17" aria-hidden="true">
        <path
          d="M20.6 14.6A8.8 8.8 0 0 1 9.4 3.4a8.8 8.8 0 1 0 11.2 11.2Z"
          fill="currentColor"></path>
      </svg>
    </button>
    <slot />
    <script>
      // One ticker drives every counter on the page. Each [data-since] holds
      // an epoch-ms start; children tagged data-d/h/m/s receive the pieces.
      const pad = (n: number) => String(n).padStart(2, '0');
      const set = (el: Element | null, value: string) => {
        if (el && el.textContent !== value) el.textContent = value;
      };

      function tick() {
        const now = Date.now();
        for (const root of document.querySelectorAll<HTMLElement>('[data-since]')) {
          const ms = Math.max(0, now - Number(root.dataset.since));
          const days = Math.floor(ms / 86_400_000);
          const dEl = root.querySelector('[data-d]');
          if (dEl) {
            const text = String(days);
            set(dEl, text);
            const ghost = root.querySelector('[data-ghost]');
            if (ghost && ghost.textContent?.length !== text.length) {
              ghost.textContent = '8'.repeat(text.length);
            }
          }
          const rem = ms % 86_400_000;
          set(root.querySelector('[data-h]'), pad(Math.floor(rem / 3_600_000)));
          set(root.querySelector('[data-m]'), pad(Math.floor(rem / 60_000) % 60));
          set(root.querySelector('[data-s]'), pad(Math.floor(rem / 1_000) % 60));
        }
      }

      tick();
      setInterval(tick, 1000);

      const toggle = document.getElementById('theme-toggle');
      const themeColor = document.querySelector('meta[name="theme-color"]');
      toggle?.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
        document.documentElement.dataset.theme = next;
        try {
          localStorage.setItem('theme', next);
        } catch {}
        themeColor?.setAttribute('content', next === 'light' ? '#f3f5f7' : '#07090c');
      });
    </script>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'DSEG7';
    src:
      url('/fonts/DSEG7Classic-Bold.woff2') format('woff2'),
      url('/fonts/DSEG7Classic-Bold.ttf') format('truetype');
    font-weight: 700;
    font-display: block;
  }

  @font-face {
    font-family: 'Anton';
    src: url('/fonts/Anton-Regular.ttf') format('truetype');
    font-weight: 400;
    font-display: swap;
  }

  :root {
    --bg: #07090c;
    --panel: #0d1117;
    --line: #1c2430;
    --text: #e8edf2;
    --dim: #8b97a5;
    --soft: #aab6c4;
    --gold: #f5b62e;
    --gold-bg: #1d160d;
    --gold-line: #5c4a1f;
    --gold-text: #ffd98a;
    --red-bg: #1d0d0d;
    --red-line: #5c1f1f;
    --red-text: #ff8d8d;
  }

  html[data-theme='light'] {
    --bg: #f3f5f7;
    --panel: #ffffff;
    --line: #d9e0e8;
    --text: #141b23;
    --dim: #5d6a79;
    --soft: #46535f;
    --gold: #9a6e0a;
    --gold-bg: #faf3e0;
    --gold-line: #e3cf9a;
    --gold-text: #8a6207;
    --red-bg: #fdeeee;
    --red-line: #f0c4c4;
    --red-text: #b3261e;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color-scheme: dark;
  }

  html[data-theme='light'] {
    color-scheme: light;
  }

  body {
    margin: 0;
    color: var(--text);
    font-family:
      ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  h1,
  h2,
  .display {
    font-family: 'Anton', ui-sans-serif, system-ui, sans-serif;
    font-weight: 400;
    letter-spacing: 0.02em;
    margin: 0;
  }

  /* Seven-segment counter with a dim "all segments on" ghost behind it. */
  .seg {
    position: relative;
    display: inline-flex;
    font-family: 'DSEG7', monospace;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .seg .ghost {
    position: absolute;
    inset: 0;
    opacity: 0.08;
    user-select: none;
  }

  html[data-theme='light'] .seg .ghost {
    opacity: 0.12;
  }

  .seg .digits {
    position: relative;
  }

  #theme-toggle {
    position: fixed;
    top: 0.85rem;
    right: 1rem;
    z-index: 50;
    display: grid;
    place-items: center;
    width: 2.3rem;
    height: 2.3rem;
    padding: 0;
    border: 1px solid var(--line);
    border-radius: 50%;
    background: var(--panel);
    color: var(--dim);
    cursor: pointer;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  #theme-toggle:hover {
    color: var(--text);
    border-color: var(--dim);
  }

  #theme-toggle .i-moon {
    display: none;
  }

  html[data-theme='light'] #theme-toggle .i-sun {
    display: none;
  }

  html[data-theme='light'] #theme-toggle .i-moon {
    display: block;
  }
</style>
