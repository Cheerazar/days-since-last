---
import { navGroups, type League } from '../lib/droughts';

interface Props {
  /** Slug of the league being viewed, if any. */
  current?: string;
}

const { current } = Astro.props;
const groups = navGroups();
const label = (l: League) => l.navLabel ?? l.league;
---

<nav class="sitenav">
  <a class="wordmark" href="/">DAYS SINCE LAST</a>
  <div class="groups">
    {
      groups.map((g) => {
        const active = g.columns.flatMap((c) => c.leagues).find((l) => l.slug === current);
        return (
          <details class="group">
            <summary class:list={[{ active: !!active }]}>
              {g.label}
              {active && <span class="here">· {label(active)}</span>}
              <span class="caret" aria-hidden="true">
                ▾
              </span>
            </summary>
            <div class:list={['panel', { wide: g.columns.length > 1 }]}>
              {g.columns.map((col) => (
                <div class="col">
                  {col.label && <p class="colhead">{col.label}</p>}
                  {col.leagues.map((l) => (
                    <a
                      href={`/${l.slug}/`}
                      class:list={[{ active: l.slug === current }]}
                      title={l.navLabel ? l.league : undefined}
                    >
                      {label(l)}
                    </a>
                  ))}
                </div>
              ))}
            </div>
          </details>
        );
      })
    }
  </div>
</nav>

<script>
  // One dropdown open at a time; any click outside the nav closes them.
  const details = [...document.querySelectorAll<HTMLDetailsElement>('.sitenav details')];
  for (const d of details) {
    d.addEventListener('toggle', () => {
      if (d.open) for (const o of details) if (o !== d) o.open = false;
    });
  }
  document.addEventListener('click', (e) => {
    if (e.target instanceof Element && e.target.closest('.sitenav details')) return;
    for (const d of details) d.open = false;
  });
</script>

<style>
  .sitenav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 1160px;
    margin: 0 auto;
    /* right padding keeps the nav clear of the fixed theme toggle */
    padding: 1rem 4rem 1rem 1.25rem;
  }

  .wordmark {
    font-family: 'Anton', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.14em;
    white-space: nowrap;
  }

  .groups {
    display: flex;
    gap: 0.5rem;
  }

  .group {
    position: relative;
  }

  summary {
    list-style: none;
    cursor: pointer;
    user-select: none;
    padding: 0.35rem 0.8rem;
    border: 1px solid transparent;
    border-radius: 99px;
    color: var(--dim);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    white-space: nowrap;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary:hover,
  .group[open] summary,
  summary.active {
    color: var(--text);
  }

  .group[open] summary,
  summary.active {
    border-color: var(--line);
    background: var(--panel);
  }

  .here {
    margin-left: 0.35rem;
  }

  .caret {
    display: inline-block;
    margin-left: 0.35rem;
    font-size: 0.6rem;
    transition: transform 0.15s;
  }

  .group[open] .caret {
    transform: rotate(180deg);
  }

  .panel {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    z-index: 50;
    display: flex;
    gap: 1.75rem;
    padding: 0.9rem 1.2rem 1rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 14px;
    min-width: max-content;
  }

  .colhead {
    margin: 0 0 0.35rem;
    color: var(--dim);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.75;
  }

  .panel a {
    display: block;
    padding: 0.28rem 0;
    color: var(--dim);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    white-space: nowrap;
    transition: color 0.15s;
  }

  .panel a:hover,
  .panel a.active {
    color: var(--text);
  }

  /* On phones the nav stacks and the panels open in-flow as accordions. */
  @media (max-width: 640px) {
    .sitenav {
      flex-direction: column;
      gap: 0.6rem;
      padding: 1rem 1.25rem 0.5rem;
    }

    .groups {
      justify-content: center;
      width: 100%;
    }

    /* Panels open in-flow, pushing the page down like an accordion. */
    .panel {
      position: static;
      margin-top: 0.5rem;
      justify-content: center;
    }
  }
</style>
